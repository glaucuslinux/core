configure() {
  set --
  if [ -n "${bootstrap-}" ]; then
    set -- \
        glaucus-meson \
        --cross-file="$core"/muon/files/meson.cross \
        -Dxz=disabled \
        -Dzlib=disabled
  else
    set -- \
        glaucus-muon
  fi

    "$@" \
    -Ddistconfdir=/usr/lib \
    -Dmoduledir=/usr/lib/modules \
    -Dbashcompletiondir=no \
    -Dfishcompletiondir=no \
    -Dzshcompletiondir=no \
    -Dmanpages=false \
    build
}

build() {
  if [ -n "${bootstrap-}" ]; then
    meson compile \
      -C build
  else
    samu \
      -C build
  fi

}

package() {
  if [ -n "${bootstrap-}" ]; then
    DESTDIR="$dir" \
    meson install \
      -C build
  else
    DESTDIR="$dir" \
    muon \
      -C build \
      install
  fi

  cp -fPp "$core"/$nom/files/search.conf "$dir"/usr/lib/depmod.d
}
