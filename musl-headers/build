prepare() {
  cd "$tmp/$nom/musl-$ver"
}

package() {
  make \
    exec_prefix=/usr \
    bindir=/usr/bin \
    prefix=/usr \
    libdir=/usr/lib \
    syslibdir=/usr/lib \
    ARCH=x86_64 \
    DESTDIR="$dir" \
    install-headers
}
