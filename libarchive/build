prepare() {
  patch \
    -i "$core/$nom/patches/glaucus/0001-fix-pkg-config-file.patch" \
    -p 0

  ./build/autogen.sh
}

configure() {
  set --

  if [ -n "${bootstrap-}" ]; then
    set -- \
        --build="$build" \
        --host="$host"
  fi

  set -- \
    "$@" \
    --disable-static \
    --disable-bsdcpio \
    --disable-rpath \
    --enable-posix-regex-lib=libpcre2posix \
    --disable-xattr \
    --disable-acl \
    --with-pic \
    --without-libb2 \
    --without-iconv \
    --without-cng \
    --without-xml2

  glaucus-configure \
    "$@"
}

build() {
  make
}

check() {
  make \
    check
}

package() {
  make \
    DESTDIR="$dir" \
    install-strip

  # Compatibility symlinks
  ln -fs bsdtar "$dir"/usr/bin/tar
  ln -fs bsdunzip "$dir"/usr/bin/unzip
}
