prepare() {
  cp -fPpR "$tmp"/nim-csources/csources_v3 "$tmp/$nom/Nim-$ver"

  cd "$tmp/$nom/Nim-$ver"/csources_v3
}

build() {
  make \
    CFLAGS="-Ic_code -w -fmax-errors=3 -fno-strict-aliasing -fno-ident -fno-math-errno $CFLAGS" \
    LDFLAGS="-ldl -lm -lrt $LDFLAGS"

  cd "$tmp/$nom/Nim-$ver"

  bin/"$nom" compile \
    -d:release \
    -d:useMalloc \
    -d:strip \
    --os:linux \
    --cpu:amd64 \
    --passC:"$CFLAGS" \
    --passL:"$LDFLAGS" \
    --skipUserCfg \
    --skipParentCfg \
    --noNimblePath \
    koch

  ./koch boot \
    -d:release \
    -d:leanCompiler \
    -d:useMalloc \
    -d:strip \
    --os:linux \
    --cpu:amd64 \
    --passC:"$CFLAGS" \
    --passL:"$LDFLAGS" \
    --skipUserCfg \
    --skipParentCfg \
    --noNimblePath
}

package() {
  ./koch install "$dir"/usr/lib

  ln -fs ../lib/"$nom/bin/$nom" "$dir"/usr/bin
}
