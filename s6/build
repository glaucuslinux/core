prepare() {
  patch \
    -i "$core/$nom/patches/glaucus/0001-use-gnu-hash-style.patch" \
    -p 0
}

configure() {
  set --

  if [ -n "${bootstrap-}" ]; then
    set -- \
        --host="$host" \
        --with-sysdeps="$dir"/usr/lib/skalibs/sysdeps \
        --with-include="$dir"/usr/include \
        --with-lib="$dir"/usr/lib \
        --with-dynlib="$dir"/usr/lib
  fi

  set -- \
      "$@" \
      --prefix=/usr \
      --exec-prefix=/usr \
      --dynlibdir=/usr/lib \
      --bindir=/usr/bin \
      --libexecdir=/usr/lib \
      --libdir=/usr/lib \
      --sysconfdir=/etc \
      --pkgconfdir=/usr/lib/pkgconfig \
      --with-pkgconfig \
      --enable-shared \
      --disable-static \
      --disable-allstatic \
      --enable-pkgconfig \
      --disable-aliases-symlinks

  ./configure \
    "$@"
}

build() {
  make \
    AR="$AR" \
    RANLIB="$RANLIB" \
    STRIP="$STRIP" \
    strip
}

package() {
  make \
    DESTDIR="$dir" \
    install
}
