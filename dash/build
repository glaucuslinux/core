prepare() {
  autoreconf -vfis
}

configure() {
  set --
  if [ -n "${bootstrap-}" ]; then
    set -- \
        --build="$build" \
        --host="$host"
  fi

  LIBS="-lterminfo -ledit" \
  glaucus-configure \
    "$@" \
    --with-libedit
}

build() {
  LIBS="-lterminfo -ledit" \
  make
}

check() {
  make \
    check

  ./src/$nom -c 'echo ok'
}

package() {
  make \
    DESTDIR="$dir" \
    install-strip

  ln -fs $nom "$dir"/usr/bin/sh

  if [ -n "${bootstrap-}" ]; then
    ln -fs $nom "$dir"/usr/bin/yash
  fi
}
