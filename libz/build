configure() {
  set --

  if [ -n "${bootstrap-}" ]; then
    set -- \
        --build="$build" \
        --host="$host"
  fi

  set -- \
      --prefix=/usr \
      --exec-prefix=/usr \
      --bindir=/usr/bin \
      --sbindir=/usr/bin \
      --libexecdir=/usr/lib \
      --sysconfdir=/etc \
      --sharedstatedir=/var/lib \
      --localstatedir=/var \
      --libdir=/usr/lib \
      "$@" \
      --disable-static

  ./configure "$@"
}

build() {
  make
}

package() {
  make \
    DESTDIR="$dir" \
    install
}
