prepare() {
  touch \
    aclocal.m4 \
    Makefile.in
}

configure() {
  set --

  if [ -n "${bootstrap-}" ]; then
    set -- \
        --build="$build" \
        --host="$host"
  fi

  set -- \
      "$@" \
      --enable-threads=posix \
      --disable-rpath \
      --enable-changeword \
      --disable-nls \
      --with-packager="$PRETTY_NAME" \
      --with-packager-bug-reports=https://github.com/glaucuslinux/glaucus/issues

  glaucus-configure \
    "$@"
}

build() {
  make
}

check() {
  make \
    check
}

package() {
  make \
    DESTDIR="$dir" \
    install-strip
}
