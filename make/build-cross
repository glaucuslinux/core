prepare() {
  patch \
    -i "$core"/$nom/patches/alpine/getopt-gcc15.patch \
    -p 1

  autoreconf -vfis
}

configure() {
  "$core"/autoconf/files/glaucus-configure \
    --build=$build \
    --host=$host \
    --disable-nls \
    --disable-rpath \
    --without-guile
}

build() {
  $nom
}

package() {
  $nom \
    DESTDIR="$cross" \
    install-strip
}
