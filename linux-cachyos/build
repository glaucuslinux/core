package() {
  mkdir -p \
    "$dir"/boot \
    "$dir"/usr/lib

  mv -f "$tmp/$nom/usr/lib/modules/$ver-cachyos/vmlinuz" "$dir"/boot
  mv -f "$tmp/$nom/usr/lib/modules" "$dir"/usr/lib

  depmod -b "$dir" "$ver"-cachyos
}
