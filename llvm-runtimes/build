prepare() {
  cd "$tmp/$nom/llvm-project-$ver.src/runtimes"
}

configure() {
  glaucus-cmake \
    -B build \
    -DBENCHMARK_INSTALL_DOCS=OFF \
    -DCMAKE_ASM_COMPILER="$CC" \
    -DCMAKE_ASM_COMPILER_TARGET="$host" \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_C_COMPILER="$CC" \
    -DCMAKE_C_COMPILER_TARGET="$host" \
    -DCMAKE_C_COMPILER_WORKS=ON \
    -DCMAKE_CXX_COMPILER="$CXX" \
    -DCMAKE_CXX_COMPILER_TARGET="$host" \
    -DCMAKE_CXX_COMPILER_WORKS=ON \
    -DCMAKE_FIND_ROOT_PATH="$dir" \
    -DCMAKE_FIND_ROOT_PATH_MODE_INCLUDE=ONLY \
    -DCMAKE_FIND_ROOT_PATH_MODE_LIBRARY=ONLY \
    -DCMAKE_FIND_ROOT_PATH_MODE_PROGRAM=NEVER \
    -DCMAKE_SYSROOT="$dir" \
    -DLIBCXXABI_ENABLE_SHARED=ON \
    -DLIBCXXABI_ENABLE_STATIC=ON \
    -DLIBCXXABI_USE_COMPILER_RT=ON \
    -DLIBCXXABI_USE_LLVM_UNWINDER=ON \
    -DLIBCXX_CXX_ABI=libcxxabi \
    -DLIBCXX_ENABLE_SHARED=ON \
    -DLIBCXX_ENABLE_STATIC=ON \
    -DLIBCXX_ENABLE_THREADS=ON \
    -DLIBCXX_HARDENING_MODE=fast \
    -DLIBCXX_HAS_MUSL_LIBC=ON \
    -DLIBCXX_USE_COMPILER_RT=ON \
    -DLIBUNWIND_ENABLE_ASSERTIONS=OFF \
    -DLIBUNWIND_ENABLE_CET=OFF \
    -DLIBUNWIND_ENABLE_CROSS_UNWINDING=ON \
    -DLIBUNWIND_ENABLE_SHARED=ON \
    -DLIBUNWIND_ENABLE_STATIC=ON \
    -DLIBUNWIND_ENABLE_THREADS=ON \
    -DLIBUNWIND_HIDE_SYMBOLS=ON \
    -DLIBUNWIND_INCLUDE_DOCS=OFF \
    -DLIBUNWIND_INCLUDE_TESTS=OFF \
    -DLIBUNWIND_INSTALL_HEADERS=ON \
    -DLIBUNWIND_INSTALL_LIBRARY=ON \
    -DLIBUNWIND_INSTALL_SHARED_LIBRARY=ON \
    -DLIBUNWIND_INSTALL_STATIC_LIBRARY=ON \
    -DLIBUNWIND_USE_COMPILER_RT=ON \
    -DLLVM_DEFAULT_TARGET_TRIPLE="$host" \
    -DLLVM_ENABLE_PER_TARGET_RUNTIME_DIR=ON \
    -DLLVM_ENABLE_RUNTIMES='libunwind;libcxxabi;libcxx'
}

build() {
  make \
    -C build
}

package() {
  make \
    -C build \
    DESTDIR="$dir" \
    install/strip

  cp -fPpR "$dir"/usr/lib/$host/* "$dir"/usr/lib
  # ln -fs "$host"/libc++.so.1.0 "$dir"/usr/lib
  # ln -fs "$host"/libc++abi.so.1.0 "$dir"/usr/lib
  # ln -fs "$host"/libunwind.so.1.0 "$dir"/usr/lib
}
