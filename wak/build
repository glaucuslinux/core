configure() {
  ./configure \
    --prefix=/usr
}

build() {
  make
}

package() {
  mkdir -p "$dir/usr/bin"
  mv -f "$nom" "$dir/usr/bin"

  # Compatibility symlinks
  ln -fs "$nom" "$dir/usr/bin/awk"
  ln -fs "$nom" "$dir/usr/bin/gawk"
}
