prepare() {
  ./autogen.sh

  touch doc/"$nom".1
}

configure() {
  set --

  if [ -n "${bootstrap-}" ]; then
    set -- env \
        ac_cv_func_malloc_0_nonnull=yes \
        ac_cv_func_realloc_0_nonnull=yes \
        glaucus-configure \
          --build="$build" \
          --host="$host"
  else
    set -- \
        glaucus-configure
  fi

  "$@" \
    --disable-static \
    --enable-pic \
    --disable-nls \
    --disable-rpath \
    --disable-libfl \
    --disable-bootstrap
}

build() {
  make \
    -j 1
}

check() {
  make \
    check
}

package() {
  make \
    DESTDIR="$dir" \
    install-strip

  ln -fs "$nom" "$dir"/usr/bin/lex
}
